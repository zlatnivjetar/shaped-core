#!/bin/bash

# RoomCloud Password Updater
# Quick script to update RoomCloud password for a single client
# Usage: rcpassword

set -e

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Save current directory
ORIGINAL_DIR=$(pwd)

# Function to cleanup and return to original directory
cleanup() {
    cd "$ORIGINAL_DIR"
}

# Set trap to always return to original directory
trap cleanup EXIT

echo -e "${BLUE}╔═══════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║   RoomCloud Password Updater              ║${NC}"
echo -e "${BLUE}╚═══════════════════════════════════════════╝${NC}"
echo ""

# Prompt for client URL
read -p "Enter client URL: " CLIENT_URL

if [ -z "$CLIENT_URL" ]; then
    echo -e "${RED}✗ Client URL cannot be empty${NC}"
    exit 1
fi

# Prompt for new password
read -p "Enter new RoomCloud password: " NEW_PASSWORD

if [ -z "$NEW_PASSWORD" ]; then
    echo -e "${RED}✗ Password cannot be empty${NC}"
    exit 1
fi

# Construct path
CLIENT_PATH="domains/$CLIENT_URL/public_html"

# Check if path exists
if [ ! -d "$CLIENT_PATH" ]; then
    echo -e "${RED}✗ Directory not found: $CLIENT_PATH${NC}"
    echo -e "${YELLOW}  Current directory: $(pwd)${NC}"
    exit 1
fi

echo ""
echo -e "${BLUE}ℹ Updating RoomCloud password for $CLIENT_URL...${NC}"
echo ""

# Change to client directory and run command
cd "$CLIENT_PATH"

# Run the update command with test
if wp roomcloud update_password "$NEW_PASSWORD" --test --allow-root 2>&1; then
    echo ""
    echo -e "${GREEN}╔═══════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║   ✓ Password Updated Successfully!       ║${NC}"
    echo -e "${GREEN}╚═══════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}✓ Client: $CLIENT_URL${NC}"
    echo -e "${GREEN}✓ Connection tested and verified${NC}"
else
    echo ""
    echo -e "${RED}╔═══════════════════════════════════════════╗${NC}"
    echo -e "${RED}║   ✗ Update Failed!                        ║${NC}"
    echo -e "${RED}╚═══════════════════════════════════════════╝${NC}"
    exit 1
fi
